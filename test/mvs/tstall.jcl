//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSTSPRT DD SYSOUT=*
//SYSPRINT DD SYSOUT=*
//SYSTSIN  DD *
 CALL 'IBMUSER.REXX370.V0R1M0D.LOAD(TSTPRSR)'
/*
//TSAY    EXEC PGM=IKJEFT01,DYNAMNBR=50,REGION=4M,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSTSPRT DD SYSOUT=*
//SYSPRINT DD SYSOUT=*
//SYSTSIN  DD *
 CALL 'IBMUSER.REXX370.V0R1M0D.LOAD(TSTSAY)'
/*
//TCTRL   EXEC PGM=IKJEFT01,DYNAMNBR=50,REGION=4M,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
