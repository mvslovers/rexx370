//TSTALLB  JOB (A),'REXX370 TESTS',REGION=4M,
//           CLASS=A,MSGCLASS=H,MSGLEVEL=(1,1),
//           NOTIFY=IBMUSER
//*---------------------------------------------------------------
//* Runs all REXX/370 test modules twice: first as pure batch
//* (EXEC PGM=TST*), then as TSO background (IKJEFT01 CALL).
//* COND=EVEN on every step so a failure in one test does not
//* prevent the remaining ones from running — collect all
//* results in a single job output.
//*---------------------------------------------------------------
//*---------------------------------------------------------------
//* Part 1 — pure batch invocations
//*---------------------------------------------------------------
//BANCH   EXEC PGM=TSTANCH,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BTOKN   EXEC PGM=TSTTOKN,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BPHAS1  EXEC PGM=TSTPHAS1,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BANRM   EXEC PGM=TSTANRM,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BANSL   EXEC PGM=TSTANSL,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BINIT   EXEC PGM=TSTINIT,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BFIND   EXEC PGM=TSTFIND,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BTERM   EXEC PGM=TSTTERM,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BLSTR   EXEC PGM=TSTLSTR,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BVPOL   EXEC PGM=TSTVPOL,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BPRSR   EXEC PGM=TSTPRSR,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BSAY    EXEC PGM=TSTSAY,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BCTRL   EXEC PGM=TSTCTRL,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BPARSE  EXEC PGM=TSTPARSE,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BPROC   EXEC PGM=TSTPROC,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BHELO   EXEC PGM=TSTHELO,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BARIT   EXEC PGM=TSTARIT,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BAREXT  EXEC PGM=TSTAREXT,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BBIF    EXEC PGM=TSTBIF,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BBIFS   EXEC PGM=TSTBIFS,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BTIM    EXEC PGM=TSTTIM,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BTRACE  EXEC PGM=TSTTRACE,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//BADDR   EXEC PGM=TSTADDR,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSPRINT DD SYSOUT=*
//*---------------------------------------------------------------
//* Part 2 — TSO background invocations (IKJEFT01 CALL)
//*---------------------------------------------------------------
//TANCH   EXEC PGM=IKJEFT01,DYNAMNBR=50,REGION=4M,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSTSPRT DD SYSOUT=*
//SYSPRINT DD SYSOUT=*
//SYSTSIN  DD *
 CALL 'IBMUSER.REXX370.V0R1M0D.LOAD(TSTANCH)'
/*
//TTOKN   EXEC PGM=IKJEFT01,DYNAMNBR=50,REGION=4M,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSTSPRT DD SYSOUT=*
//SYSPRINT DD SYSOUT=*
//SYSTSIN  DD *
 CALL 'IBMUSER.REXX370.V0R1M0D.LOAD(TSTTOKN)'
/*
//TPHAS1  EXEC PGM=IKJEFT01,DYNAMNBR=50,REGION=4M,COND=EVEN
//STEPLIB  DD DSN=IBMUSER.REXX370.V0R1M0D.LOAD,DISP=SHR
//SYSTSPRT DD SYSOUT=*
//SYSPRINT DD SYSOUT=*
//SYSTSIN  DD *
 CALL 'IBMUSER.REXX370.V0R1M0D.LOAD(TSTPHAS1)'
